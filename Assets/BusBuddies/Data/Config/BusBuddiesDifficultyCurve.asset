%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
# Bus Buddies default 40-level difficulty curve. SEEDED SENSIBLE DEFAULTS — all
# values are TUNABLE via the Difficulty Curve window (Window ▸ Hoppa ▸ BusBuddies
# ▸ Difficulty Curve). 30×30 board throughout; the DESIGNER difficulty model drives
# each tier via the six knobs (Buses Chunks / Deviation / Columns / Difficulty +
# two rules), with an ascending ramp Intro→Expert. APS is a measured read-out, not
# a target.
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 786cdec8f044c6340b651165ff74f228, type: 3}
  m_Name: BusBuddiesDifficultyCurve
  m_EditorClassIdentifier: Hoppa.BusBuddies.Editor::Hoppa.BusBuddies.Editor.BusBuddiesDifficultyCurveConfig
  Presets:
  - Name: Intro
    GridWidth: 30
    GridHeight: 30
    MaxColors: 3
    ConveyorSlots: 5
    Difficulty:
      BusesChunks: 1
      DeviationPercent: 0.2
      Columns: 1
      Difficulty: 1
      NoSingleBusColor: 0
      RoundToFive: 0
  - Name: Easy
    GridWidth: 30
    GridHeight: 30
    MaxColors: 4
    ConveyorSlots: 5
    Difficulty:
      BusesChunks: 2
      DeviationPercent: 0.35
      Columns: 2
      Difficulty: 2
      NoSingleBusColor: 0
      RoundToFive: 0
  - Name: Medium
    GridWidth: 30
    GridHeight: 30
    MaxColors: 5
    ConveyorSlots: 5
    Difficulty:
      BusesChunks: 3
      DeviationPercent: 0.5
      Columns: 3
      Difficulty: 3
      NoSingleBusColor: 0
      RoundToFive: 0
  - Name: Hard
    GridWidth: 30
    GridHeight: 30
    MaxColors: 6
    ConveyorSlots: 5
    Difficulty:
      BusesChunks: 4
      DeviationPercent: 0.65
      Columns: 4
      Difficulty: 4
      NoSingleBusColor: 1
      RoundToFive: 0
  - Name: Expert
    GridWidth: 30
    GridHeight: 30
    MaxColors: 7
    ConveyorSlots: 5
    Difficulty:
      BusesChunks: 5
      DeviationPercent: 0.8
      Columns: 5
      Difficulty: 5
      NoSingleBusColor: 1
      RoundToFive: 1
  Curve:
  - TierName: Intro
    LevelCount: 8
  - TierName: Easy
    LevelCount: 8
  - TierName: Medium
    LevelCount: 8
  - TierName: Hard
    LevelCount: 8
  - TierName: Expert
    LevelCount: 8
